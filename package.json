{
  "name": "@vercel/skills",
  "version": "0.1.0",
  "description": "A collection of reusable AI agent skills for Vercel projects",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "vercel",
    "llm",
    "tools"
  ],
  "author": "Vercel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel-labs/skills.git"
  },
  "bugs": {
    "url": "https://github.com/vercel-labs/skills/issues"
  },
  "homepage": "https://github.com/vercel-labs/skills#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
